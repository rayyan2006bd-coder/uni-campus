rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /accommodationBookings/{bookingId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /coldStorageBookings/{bookingId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /safetyOrders/{orderId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /jobApplications/{applicationId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /shuttleBookings/{bookingId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /mealSubscriptions/{subscriptionId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
    match /marketplaceItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || resource.data.sellerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
    }
    match /laundryBookings/{bookingId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
  }
}
